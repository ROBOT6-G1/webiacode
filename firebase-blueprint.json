    "app_users": {
      "title": "App End Users",
      "description": "End users registered on websites generated by DEVWEBIA",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "email": { "type": "string" },
        "user_number": { "type": "number" },
