{
  "entities": {
    "profiles": {
      "title": "Profiles",
      "description": "User profiles with credits, plan, and subscriptions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "display_name": { "type": "string" },
        "credits": { "type": "number" },
        "plan": { "type": "string" },
        "plan_expires_at": { "type": "string" },
        "ai_sub_expires_at": { "type": "string" },
        "referral_code": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["email", "credits", "plan"]
    },
    "user_roles": {
      "title": "User Roles",
      "description": "Admin roles mapping",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["user_id", "role"]
    },
    "projects": {
      "title": "Projects",
      "description": "User created web projects",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "files": { "type": "object" },
        "html_content": { "type": "string" },
        "css_content": { "type": "string" },
        "js_content": { "type": "string" },
