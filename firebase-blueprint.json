        "vercel_project_id": { "type": "string" },
        "vercel_url": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["user_id", "name"]
    },
    "messages": {
      "title": "Messages",
      "description": "Chat history for project generation",
      "type": "object",
